<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
    <class>KWorkspacesConfig</class>
    <widget class="QWidget" name="KWorkspacesConfig">
        <layout class="QVBoxLayout" name="mainLayout">
            <item>
                <widget class="QCheckBox" name="kcfg_keepEmptyMiddleDesktops">
                    <property name="toolTip">
                        <string>When off, an empty row/column beyond the required margin is cleaned up automatically. When on, extra empty margin is left alone once created instead of being shrunk back.</string>
                    </property>
                    <property name="text">
                        <string>Keep empty desktops between occupied ones</string>
                    </property>
                </widget>
            </item>
            <item>
                <layout class="QHBoxLayout" name="maxDesktopsLayout">
                    <item>
                        <widget class="QLabel" name="labelMaxDesktops">
                            <property name="text">
                                <string>Maximum desktops:</string>
                            </property>
                        </widget>
                    </item>
                    <item>
                        <widget class="QSpinBox" name="kcfg_maxDesktops">
                            <property name="toolTip">
                                <string>Safety cap on total desktop count -- growth requests beyond this are silently ignored.</string>
                            </property>
                            <property name="minimum">
                                <number>2</number>
                            </property>
                            <property name="maximum">
                                <number>1000</number>
                            </property>
                            <property name="value">
                                <number>20</number>
                            </property>
                        </widget>
                    </item>
                </layout>
            </item>
            <item>
                <spacer name="spacer">
                    <property name="orientation">
                        <enum>Qt::Vertical</enum>
                    </property>
                    <property name="sizeHint" stdset="0">
                        <size>
                            <width>20</width>
                            <height>40</height>
                        </size>
                    </property>
                </spacer>
            </item>
        </layout>
    </widget>
    <resources/>
    <connections/>
</ui>
